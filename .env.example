# ==============================================
# COKE LOGGER - Environment Variables Template
# ==============================================
# Copy this file to .env.local and fill with your actual values

# ---------------------------------------------
# Database - Neon PostgreSQL
# ---------------------------------------------
# Get your connection strings from: https://console.neon.tech
# 
# Development: Use your Neon "dev" branch POOLED connection
# Production: Use your Neon "main" branch POOLED connection
#
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your-password@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# ---------------------------------------------
# Better Auth
# ---------------------------------------------
# Generate a secure secret: openssl rand -base64 32
# MUST be different in production vs development
BETTER_AUTH_SECRET=your-secret-min-32-characters-long

# Base URL of your application
# Development: http://localhost:3000 (or 3001 if port 3000 is in use)
# Production: https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------
# Optional - Environment Indicator
# ---------------------------------------------
# NODE_ENV is auto-set by Next.js (development/production)
# No need to define manually
